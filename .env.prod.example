# =================================================================
# Prism CMS — 生产环境变量模板
# 使用：cp .env.prod.example .env.prod  然后修改下面所有值
# .env.prod 已被 .gitignore 排除，不会提交到 Git
# =================================================================

# ── 域名 ──────────────────────────────────────────────────────────
# 带协议，末尾不加斜杠
# 有 SSL：https://prism.example.com
# 无 SSL：http://1.2.3.4
# 带协议，末尾不加斜杠；此值会同时用于：
#   - CORS_ORIGIN（后端跨域白名单）
#   - NEXT_PUBLIC_API_BASE（门户客户端 API 地址）
DOMAIN=https://prism.example.com

# ── 站点 ──────────────────────────────────────────────────────────
SITE_NAME=Prism

# ── MySQL ─────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=请替换为强密码_root
MYSQL_DATABASE=cms_prod
MYSQL_USER=cms
MYSQL_PASSWORD=请替换为强密码_cms

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=请替换为强密码_redis

# ── JWT（建议用 openssl rand -hex 32 生成）────────────────────────
JWT_SECRET=请替换为64位随机字符串
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=请替换为另一个64位随机字符串
JWT_REFRESH_EXPIRES_IN=7d

# ── 数据库同步（首次部署改为 true，建完表后改回 false）──────────────
# true  → TypeORM 自动建表（首次部署用）
# false → 不自动变更表结构（安全，日常运行用）
DB_SYNC=false
