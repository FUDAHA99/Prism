# 应用配置
NODE_ENV=development
APP_NAME=cms-backend
APP_PORT=3000
APP_URL=http://localhost:3000

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=cms_db
DATABASE_USER=cms_user
DATABASE_PASSWORD=cms_password
DATABASE_URL=postgresql://cms_user:cms_password@localhost:5432/cms_db?schema=public

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# 安全配置
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_COUNT=100

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_DEST=./uploads

# 阿里云OSS配置
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=cms-bucket
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# CORS配置
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# 日志配置
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# 邮件配置（可选）
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASS=your-email-password
MAIL_FROM=noreply@your-domain.com

# 监控配置
PROMETHEUS_ENABLED=true
